# =========================
# Dependabot tool outputs
# =========================

# Default output folders from this script
dependabot_summary_*/

# Generic safety net (in case someone renames output dirs)
*_summary_*/

# Raw output files (high risk if committed)
*.csv
*.json

# Keep manually curated docs if needed
!README.md
!examples/*.md


# =========================
# Python
# =========================

__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Distribution / packaging
build/
dist/
*.egg-info/

# Pytest / coverage
.pytest_cache/
.coverage
htmlcov/

# Mypy / type checking
.mypy_cache/


# =========================
# OS / Editor junk
# =========================

# macOS
.DS_Store

# Windows
Thumbs.db

# VSCode
.vscode/

# JetBrains
.idea/


# =========================
# Secrets / local configs
# =========================

.env
.env.*
